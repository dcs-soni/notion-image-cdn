# Notion Image CDN — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info                  # fatal | error | warn | info | debug | trace
NODE_ENV=development            # development | production

STORAGE_BACKEND=fs              # fs | s3 | r2
CACHE_DIR=./cache               # Used when STORAGE_BACKEND=fs

# S3-Compatible Storage (R2, S3, MinIO, Backblaze B2)
# S3_BUCKET=notion-image-cdn-cache
# S3_REGION=auto
# S3_ENDPOINT=                  # Required for R2/MinIO (e.g., https://<account>.r2.cloudflarestorage.com)
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ---- Edge Cache (L2) ----
# REDIS_URL=redis://localhost:6379

ALLOWED_DOMAINS=prod-files-secure.s3.us-west-2.amazonaws.com,s3.us-west-2.amazonaws.com,images.unsplash.com
MAX_IMAGE_SIZE_BYTES=26214400   # 25MB
UPSTREAM_TIMEOUT_MS=15000       # 15 seconds
RATE_LIMIT_PER_MINUTE=60              # Global fallback: requests/min per IP for unlisted routes
RATE_LIMIT_PROXY=20                   # /api/v1/proxy: upstream fetch + Sharp + R2 write (most expensive)
RATE_LIMIT_IMAGE=120                  # /img/*: usually a cache hit (cheapest)
RATE_LIMIT_CACHE_PURGE=5              # DELETE /api/v1/cache: triggers expensive re-fetches (destructive)
RATE_LIMIT_HEALTH=100                 # /health + /api/v1/stats: lightweight but abusable

API_KEYS_ENABLED=false
# HMAC_SECRET=                  # For signed URLs (optional)

# ---- CORS ----
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com


# API_KEYS=key1,key2              # Required when API_KEYS_ENABLED=true
CACHE_TTL_SECONDS=86400           # Controls L2/s-maxage TTL